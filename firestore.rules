rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test probe
    match /test/{id} {
      allow read: if true;
    }

    // Hardened Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function hasRole(authObj, role) {
      return authObj != null && 
        exists(/databases/$(database)/documents/users/$(authObj.uid)) && 
        get(/databases/$(database)/documents/users/$(authObj.uid)).data.get('role', '') == role;
    }

    function isAdmin(authObj) {
      return authObj != null && (
        hasRole(authObj, 'Admin') || 
        (authObj.token != null && 'email' in authObj.token && authObj.token.email in ['admin@astha.com', 'rafiadnan233@gmail.com'])
      );
    }

    function isCommittee(authObj) {
      return authObj != null && (hasRole(authObj, 'Committee Member') || isAdmin(authObj));
    }

    function isSecurity(authObj) {
      return authObj != null && (hasRole(authObj, 'Security Guard') || isAdmin(authObj));
    }

    function isResident(authObj) {
      return authObj != null && (hasRole(authObj, 'Resident') || isCommittee(authObj) || isAdmin(authObj));
    }

    // Users Collection
    match /users/{userId} {
      allow read, write: if true;
    }

    // Legacy User Accounts Collection
    match /userAccounts/{userId} {
      allow read, write: if true;
    }

    // Gated configurations
    match /config/{configId} {
      allow read, write: if true;
    }

    // Units registry
    match /flats/{flatId} {
      allow read, write: if true;
    }

    // Members index and directory
    match /members/{memberId} {
      allow read, write: if true;
    }

    // Maintenance billing documents
    match /maintenanceBills/{billId} {
      allow read, write: if true;
    }

    // Legacy bills & payments
    match /payments/{paymentId} {
      allow read, write: if true;
    }

    // Financial expenses ledger
    match /expenses/{expenseId} {
      allow read, write: if true;
    }

    // Public notice boards and bulletins
    match /notices/{noticeId} {
      allow read, write: if true;
    }

    // Security checkins and visitor lists
    match /visitors/{visitorId} {
      allow read, write: if true;
    }

    // Complaints ledger
    match /complaints/{complaintId} {
      allow read, write: if true;
    }

    // Society staff payrolls
    match /staff/{staffId} {
      allow read, write: if true;
    }

    // Activity audit trails
    match /activityLogs/{logId} {
      allow read, write: if true;
    }

    // Broadcast messages
    match /notifications/{notificationId} {
      allow read, write: if true;
    }

    // Unified context sync records
    match /live_data/{dataId} {
      allow read, write: if true;
    }
  }
}
